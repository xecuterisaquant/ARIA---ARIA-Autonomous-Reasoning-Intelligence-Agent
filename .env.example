# ARIA — Environment Variables
# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
PRISM_API_KEY=your_prism_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── Optional ──────────────────────────────────────────────────────────────────
# Dashboard auth token (leave empty for no auth)
ARIA_DASHBOARD_TOKEN=

# Comma-separated list of assets to trade
ARIA_ASSETS=BTC,ETH

# Seconds between trading cycles (default: 180)
ARIA_LOOP_INTERVAL=180

# Dashboard HTTP port (default: 8080)
PORT=8080
